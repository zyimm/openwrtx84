#==================== 1.平台&分区配置（只编译ext4，裸盘镜像手动扩容） ====================
CONFIG_TARGET_x86=y
CONFIG_TARGET_SUBTARGET=x86_64
CONFIG_TARGET_PROFILE=GENERIC
CONFIG_TARGET_ARCH_PACKAGES=x86_64
CONFIG_TARGET_KERNEL_PARTSIZE=128
# 不固定root大小，生成整盘镜像
# CONFIG_TARGET_ROOTFS_PARTSIZE=4096
CONFIG_TARGET_ROOTFS_SQUASHFS=n
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_KERNEL_EXT4_FS=y

#==================== 2.Docker必备内核选项(25.12 6.6内核) ====================
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_PIDS=y
CONFIG_KERNEL_CGROUP_SCHED=y
CONFIG_KERNEL_CPUSETS=y
CONFIG_KERNEL_MEMCG=y
CONFIG_KERNEL_MEMCG_SWAP=y
CONFIG_KERNEL_NAMESPACES=y
CONFIG_KERNEL_NET_NS=y
CONFIG_KERNEL_PID_NS=y
CONFIG_KERNEL_USER_NS=y
CONFIG_KERNEL_SECCOMP=y
CONFIG_KERNEL_SECCOMP_FILTER=y
CONFIG_KERNEL_OVERLAY_FS=y
CONFIG_KERNEL_POSIX_MQUEUE=y
CONFIG_KERNEL_CGROUP_HUGETLB=y

#==================== 3.基础命令 + 磁盘运维工具（保留扩容工具） ====================
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_gzip=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_mount-utils=y
CONFIG_PACKAGE_kmod-loop=y
CONFIG_PACKAGE_swap-utils=y
CONFIG_PACKAGE_kmod-swap=y
# 手动扩容必备工具全保留
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_ncdu=y
CONFIG_PACKAGE_opkg=y

#==================== 4.Dropbear SSH全套 ====================
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_dropbear-convert=y
CONFIG_PACKAGE_dropbear-dbclient=y
CONFIG_PACKAGE_dropbear-keygen=y
CONFIG_PACKAGE_dropbear-ssh=y

#==================== 5.Docker全组件（25.12 compose-v2） ====================
CONFIG_PACKAGE_kmod-overlayfs=y
CONFIG_PACKAGE_bridge=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_docker-compose-v2=y

#==================== 6.基础网络防火墙 ====================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ip-full=y

#==================== 7.网卡驱动 igb(I210/I350)+e1000e ====================
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-e1000e=y
# CONFIG_PACKAGE_kmod-ixgbe=y

#==================== 8.USB多格式硬盘挂载 NTFS/FAT/exfat/XFS ====================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ohci=n
CONFIG_PACKAGE_kmod-usb-uhci=n
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_ntfs3-mount=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-cp936=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_exfat-mount=y
CONFIG_PACKAGE_kmod-fs-xfs=y
# CONFIG_PACKAGE_kmod-fs-btrfs=y

#==================== 9.Netdata系统监控 ====================
CONFIG_PACKAGE_netdata=y
CONFIG_PACKAGE_netdata-enable-autostart=y

#==================== 10.TTYD 网页远程终端 ====================
CONFIG_PACKAGE_ttyd=y
# CONFIG_PACKAGE_ttyd-ssl=y

#==================== 11.禁用无线精简固件 ====================
CONFIG_PACKAGE_wireless-tools=n
CONFIG_PACKAGE_kmod-wireless=n
CONFIG_DRIVER_WIRELESS=n
CONFIG_PACKAGE_kmod-ath=n
CONFIG_PACKAGE_kmod-brcm-wl=n

#==================== 全局附加：时区中文（硬盘中文名不乱码） ====================
CONFIG_PACKAGE_zoneinfo-core=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_locale-cn=y
CONFIG_IPV6=y

#==================== LuCI中文WEB全套 + Dockerman可视化Docker面板 ====================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-system=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-network=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-dockerman=y
# 消除依赖报错
CONFIG_PACKAGE_luci-app-mjpg-streamer=n
CONFIG_PACKAGE_onionshare-cli=n

# LuCI中文翻译
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-network-zh-cn=y
CONFIG_PACKAGE-luci-i18n-system-zh-cn=y
# WEB服务依赖
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
